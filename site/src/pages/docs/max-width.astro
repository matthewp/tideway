---
import DocsLayout from "../../layouts/DocsLayout.astro";

const widths = [
	["3xs", "16rem"], ["2xs", "18rem"], ["xs", "20rem"], ["sm", "24rem"], ["md", "28rem"],
	["lg", "32rem"], ["xl", "36rem"], ["2xl", "42rem"], ["3xl", "48rem"], ["4xl", "56rem"],
	["5xl", "64rem"], ["6xl", "72rem"], ["7xl", "80rem"], ["prose", "65ch"],
];
---

<DocsLayout
	title="Max-width tokens"
	description="Tideway max-width tokens — the container scale for capping content width."
	active="max-width"
>
	<article class="doc">
		<p class="doc__eyebrow">Tokens</p>
		<h1 class="doc__title">Max-width</h1>
		<p class="doc__lead">
			The container scale, named <code class="doc__code">--container-&#123;size&#125;</code>. Use it to cap
			page spines, cards, and text columns. <code class="doc__code">--container-prose</code> is the
			reading measure — cap running text at it to keep lines legible.
		</p>

		<section class="doc__section">
			<div class="token-table">
				{widths.map(([name, value]) => (
					<div class="token-table__row">
						<div class="token-table__meta">
							<span class="token-table__name">--container-{name}</span>
							<span class="token-table__value">{value}</span>
						</div>
						<div class="token-table__preview">
							<div class="token-table__box token-table__box--gradient" style={`width: var(--container-${name}); max-width: 100%; height: var(--space-2)`}></div>
						</div>
					</div>
				))}
			</div>
		</section>
	</article>
</DocsLayout>
