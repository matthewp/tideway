---
---

<button class="search-trigger" type="button" data-search-open aria-label="Search docs">
	<svg class="search-trigger__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
		<circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
		<path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
	</svg>
	<span class="search-trigger__label">Search</span>
	<kbd class="search-trigger__kbd">/</kbd>
</button>

<dialog class="search-dialog" data-search-dialog aria-label="Search">
	<div class="search-dialog__panel">
		<div class="search-dialog__field">
			<svg class="search-dialog__field-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
				<path d="m20 20-3.5-3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
			</svg>
			<input
				class="search-dialog__input"
				type="text"
				placeholder="Search the docs…"
				data-search-input
				autocomplete="off"
				spellcheck="false"
			/>
			<button class="search-dialog__close" type="button" data-search-close>Esc</button>
		</div>
		<div class="search-dialog__hint" data-search-hint>
			<p class="search-dialog__hint-text">Search page titles, tokens, and guides.</p>
			<ul class="search-dialog__suggestions">
				<li><button class="search-dialog__suggestion" type="button" data-search-suggestion>colors</button></li>
				<li><button class="search-dialog__suggestion" type="button" data-search-suggestion>spacing</button></li>
				<li><button class="search-dialog__suggestion" type="button" data-search-suggestion>radius</button></li>
				<li><button class="search-dialog__suggestion" type="button" data-search-suggestion>theming</button></li>
			</ul>
		</div>
		<ul class="search-dialog__results" data-search-results></ul>
		<p class="search-dialog__empty" data-search-empty hidden></p>
	</div>
</dialog>

<script is:inline>
	const dialog = document.querySelector("[data-search-dialog]");
	const input = document.querySelector("[data-search-input]");
	const resultsEl = document.querySelector("[data-search-results]");
	const emptyEl = document.querySelector("[data-search-empty]");
	const hintEl = document.querySelector("[data-search-hint]");

	if (dialog && input && resultsEl && emptyEl && hintEl) {
		// Generated by `pagefind --site dist` after the build; absent in dev.
		let pagefind;
		let debounceId;
		let activeIndex = -1;

		function resultLinks() {
			return Array.from(resultsEl.querySelectorAll(".search-dialog__result-link"));
		}

		function setActive(index) {
			const links = resultLinks();
			if (!links.length) {
				activeIndex = -1;
				return;
			}
			activeIndex = Math.max(0, Math.min(index, links.length - 1));
			for (const [i, link] of links.entries()) {
				link.classList.toggle("search-dialog__result-link--active", i === activeIndex);
			}
			links[activeIndex].scrollIntoView({ block: "nearest" });
		}

		async function loadPagefind() {
			if (pagefind !== undefined) return pagefind;
			try {
				pagefind = await import("/pagefind/pagefind.js");
			} catch {
				pagefind = null;
			}
			return pagefind;
		}

		function openDialog() {
			dialog.showModal();
			document.documentElement.style.overflow = "hidden";
			input.value = "";
			resultsEl.innerHTML = "";
			emptyEl.hidden = true;
			hintEl.hidden = false;
			activeIndex = -1;
			input.focus();
			loadPagefind();
		}

		function closeDialog() {
			dialog.close();
		}

		// Fires regardless of how the dialog closed (Esc key, backdrop click, our button).
		dialog.addEventListener("close", () => {
			document.documentElement.style.overflow = "";
		});

		for (const button of document.querySelectorAll("[data-search-open]")) {
			button.addEventListener("click", openDialog);
		}

		document.querySelector("[data-search-close]")?.addEventListener("click", closeDialog);

		dialog.addEventListener("click", (event) => {
			if (event.target === dialog) closeDialog();
		});

		document.addEventListener("keydown", (event) => {
			const mod = event.metaKey || event.ctrlKey;
			if (mod && event.key.toLowerCase() === "k") {
				event.preventDefault();
				dialog.open ? closeDialog() : openDialog();
				return;
			}
			if (event.key === "/" && !dialog.open) {
				const target = event.target;
				const editable =
					target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable;
				if (!editable) {
					event.preventDefault();
					openDialog();
				}
				return;
			}
			if (!dialog.open) return;
			if (event.key === "ArrowDown") {
				event.preventDefault();
				setActive(activeIndex + 1);
			} else if (event.key === "ArrowUp") {
				event.preventDefault();
				setActive(activeIndex - 1);
			} else if (event.key === "Enter" && activeIndex >= 0) {
				const links = resultLinks();
				const link = links[activeIndex];
				if (link && document.activeElement !== link) {
					event.preventDefault();
					link.click();
				}
			}
		});

		async function runSearch(query) {
			if (!query) {
				resultsEl.innerHTML = "";
				emptyEl.hidden = true;
				hintEl.hidden = false;
				activeIndex = -1;
				return;
			}

			hintEl.hidden = true;

			const pf = await loadPagefind();
			if (!pf) {
				resultsEl.innerHTML = "";
				emptyEl.hidden = false;
				emptyEl.textContent = "Search isn't available in dev — run a production build.";
				activeIndex = -1;
				return;
			}

			const search = await pf.search(query);
			const items = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));

			resultsEl.innerHTML = "";
			emptyEl.hidden = items.length > 0;
			emptyEl.textContent = "No results.";

			for (const item of items) {
				const li = document.createElement("li");
				li.className = "search-dialog__result";

				const a = document.createElement("a");
				a.className = "search-dialog__result-link";
				a.href = item.url;

				const title = document.createElement("span");
				title.className = "search-dialog__result-title";
				title.textContent = item.meta?.title ?? item.url;

				const excerpt = document.createElement("span");
				excerpt.className = "search-dialog__result-excerpt";
				excerpt.innerHTML = item.excerpt;

				a.append(title, excerpt);
				li.append(a);
				resultsEl.append(li);
			}

			setActive(0);
		}

		input.addEventListener("input", () => {
			const query = input.value.trim();
			window.clearTimeout(debounceId);
			debounceId = window.setTimeout(() => runSearch(query), 120);
		});

		for (const suggestion of document.querySelectorAll("[data-search-suggestion]")) {
			suggestion.addEventListener("click", () => {
				input.value = suggestion.textContent ?? "";
				input.focus();
				runSearch(input.value.trim());
			});
		}
	}
</script>
